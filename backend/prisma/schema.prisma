generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model envelopes {
  id                 Int                @id @default(autoincrement())
  user_id            Int
  name               String             @db.VarChar(100)
  currency           envelopes_currency
  target_amount      Decimal            @db.Decimal(12, 2)
  current_amount     Decimal?           @default(0.00) @db.Decimal(12, 2)
  monthly_suggestion Decimal            @db.Decimal(12, 2)
  status             envelopes_status?  @default(active)
  created_at         DateTime?          @default(now()) @db.Timestamp(0)
  completed_at       DateTime?          @db.Timestamp(0)
  users              users              @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_envelope_user")
  transactions       transactions[]

  @@index([user_id], map: "idx_envelopes_user")
}

model transactions {
  id          Int                   @id @default(autoincrement())
  user_id     Int
  envelope_id Int?
  currency    transactions_currency
  type        transactions_type
  amount      Decimal               @db.Decimal(12, 2)
  created_at  DateTime?             @default(now()) @db.Timestamp(0)
  envelopes   envelopes?            @relation(fields: [envelope_id], references: [id], onUpdate: NoAction, map: "fk_transaction_envelope")
  users       users                 @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_transaction_user")

  @@index([envelope_id], map: "idx_transactions_envelope")
  @@index([user_id], map: "idx_transactions_user")
}

model user_balances {
  id       Int                    @id @default(autoincrement())
  user_id  Int
  currency user_balances_currency
  balance  Decimal?               @default(0.00) @db.Decimal(12, 2)
  users    users                  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_balance_user")

  @@unique([user_id, currency], map: "unique_user_currency")
}

model users {
  id            Int             @id @default(autoincrement())
  name          String          @db.VarChar(100)
  email         String          @unique(map: "email") @db.VarChar(150)
  password      String          @db.VarChar(255)
  created_at    DateTime?       @default(now()) @db.Timestamp(0)
  updated_at    DateTime?       @default(now()) @db.Timestamp(0)
  envelopes     envelopes[]
  transactions  transactions[]
  user_balances user_balances[]
}

enum user_balances_currency {
  EUR
  COP
}

enum envelopes_currency {
  EUR
  COP
}

enum transactions_currency {
  EUR
  COP
}

enum transactions_type {
  deposit_envelope
  deposit_balance
  transfer_balance_to_envelope
}

enum envelopes_status {
  active
  completed
}
